# ==============================================================================
# ServiceDesk Radar — ai-core / Infrastructure
# .env.example  (Step 2)
#
# Copy to `.env` and adjust per environment.
# NOTE: No real secrets belong in this file or in the repo (Critical Rule 7).
# NOTE: All tunable THRESHOLDS live in config/infrastructure_config.json
#       (single source of truth — Critical Rule 4). Do NOT duplicate them here.
# ==============================================================================

# ------------------------------------------------------------------------------
# Runtime environment
#   Controls the guard inside set_model_for_testing(): the mock-injection path
#   is only permitted when ENVIRONMENT=test.
#   Allowed: development | test | production
# ------------------------------------------------------------------------------
ENVIRONMENT=development

# Logging verbosity for infrastructure startup/runtime logs.
#   Allowed: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Configuration source
#   Path to the single source of truth for all thresholds (loaded at Step 1 of
#   initialize_infrastructure()). FAIL here => startup raises immediately.
# ------------------------------------------------------------------------------
INFRASTRUCTURE_CONFIG_PATH=config/infrastructure_config.json

# ------------------------------------------------------------------------------
# Embedding model cache
#   Local directory where sentence-transformers stores downloaded model weights
#   so the model is not re-downloaded on every startup. Mirrors
#   embedding.cache_dir in infrastructure_config.json.
# ------------------------------------------------------------------------------
HF_HOME=.model_cache

# ------------------------------------------------------------------------------
# Qdrant (OPTIONAL — Python cosine fallback is always the default, Rule 8)
#   These connection values are only read when qdrant.enabled = true in
#   infrastructure_config.json. They override the host/port from config when set.
#   QDRANT_API_KEY is optional and only needed for a secured Qdrant instance —
#   leave empty for local/unauthenticated dev.
# ------------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ------------------------------------------------------------------------------
# FastAPI service (ai-core host/port for local run)
# ------------------------------------------------------------------------------
AI_CORE_HOST=0.0.0.0
AI_CORE_PORT=8001
